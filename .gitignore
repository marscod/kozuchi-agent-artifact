# Heavy data archives -- hosted on Zenodo (see ../admin.md).
data/archives/*.tar.zst
data/archives/*.jsonl.zst
# Zenodo upload bundle (built by admin.md section 4.2; ~1.4 GB).
data/archives/*.zip
# But keep the manifest of expected archives / their checksums.
!data/archives/SHA256SUMS.txt
!data/archives/.gitkeep
